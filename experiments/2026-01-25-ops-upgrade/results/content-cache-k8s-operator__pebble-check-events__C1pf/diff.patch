+    def _on_pebble_check_failed(self, event) -> None:
+        """Handle a Pebble health check failure.
+
+        Args:
+            event: PebbleCheckFailedEvent fired when a check's failure threshold is reached.
+        """
+        logger.warning("Health check %s failed (threshold reached)", event.info.name)
+        self.unit.status = BlockedStatus(f"Health check '{event.info.name}' failing")
+
+    def _on_pebble_check_recovered(self, event) -> None:
+        """Handle a Pebble health check recovery.
+
+        Args:
+            event: PebbleCheckRecoveredEvent fired when a previously failed check passes.
+        """
+        logger.info("Health check %s recovered", event.info.name)
+        self.unit.status = ActiveStatus()
+
