@@ -648,3 +648,25 @@ class TestCharm:
         with open("tests/files/nginx_config_proxy_cache_revalidate.txt") as f:
             expected = f.read()
             assert harness.charm._make_nginx_config(env_config) == expected
+
+    def test_on_pebble_check_failed(self):
+        """
+        arrange: a Pebble health check has reached its failure threshold
+        act: emit pebble_check_failed event
+        assert: unit status is Blocked with the check name
+        """
+        harness = self.harness
+        container = harness.charm.unit.get_container(CONTAINER_NAME)
+        harness.charm.on["content-cache"].pebble_check_failed.emit(container, "content-cache")
+        assert harness.charm.unit.status == BlockedStatus("Health check 'content-cache' failing")
+
+    def test_on_pebble_check_recovered(self):
+        """
+        arrange: a previously failing Pebble health check has now passed
+        act: emit pebble_check_recovered event
+        assert: unit status is Active
+        """
+        harness = self.harness
+        container = harness.charm.unit.get_container(CONTAINER_NAME)
+        harness.charm.on["content-cache"].pebble_check_recovered.emit(container, "content-cache")
+        assert harness.charm.unit.status == ActiveStatus()
