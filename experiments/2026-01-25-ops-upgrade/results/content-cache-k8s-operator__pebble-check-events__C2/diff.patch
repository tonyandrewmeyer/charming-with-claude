+    def _on_pebble_check_failed(self, event: PebbleCheckFailedEvent) -> None:
+        """Handle pebble_check_failed event.
+
+        Args:
+            event: Event emitted when a Pebble health check fails.
+        """
+        if event.info.name == CONTAINER_NAME:
+            msg = f"Pebble check failed: {event.info.name}"
+            logger.error(msg)
+            self.unit.status = BlockedStatus(msg)
+        else:
+            logger.warning("Pebble check failed: %s", event.info.name)
+
+    def _on_pebble_check_recovered(self, event: PebbleCheckRecoveredEvent) -> None:
+        """Handle pebble_check_recovered event.
+
+        Args:
+            event: Event emitted when a previously failed Pebble health check recovers.
+        """
+        if event.info.name == CONTAINER_NAME:
+            logger.info("Pebble check recovered: %s", event.info.name)
+            self.unit.status = ActiveStatus("Ready")
+        else:
+            logger.info("Pebble check recovered: %s", event.info.name)
+
