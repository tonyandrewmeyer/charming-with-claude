+
+    def test_on_pebble_check_failed_content_cache(self):
+        """
+        arrange: content-cache pebble check fails
+        act: emit pebble_check_failed event for the content-cache check
+        assert: unit status is BlockedStatus with the check name
+        """
+        harness = self.harness
+        container = harness.charm.unit.get_container(CONTAINER_NAME)
+        harness.charm.on[CONTAINER_NAME].pebble_check_failed.emit(container, CONTAINER_NAME)
+        assert harness.charm.unit.status == BlockedStatus(
+            f"Pebble check failed: {CONTAINER_NAME}"
+        )
+
+    def test_on_pebble_check_recovered_content_cache(self):
+        """
+        arrange: content-cache pebble check recovers after a failure
+        act: emit pebble_check_recovered event for the content-cache check
+        assert: unit status is ActiveStatus Ready
+        """
+        harness = self.harness
+        harness.charm.unit.status = BlockedStatus(f"Pebble check failed: {CONTAINER_NAME}")
+        container = harness.charm.unit.get_container(CONTAINER_NAME)
+        harness.charm.on[CONTAINER_NAME].pebble_check_recovered.emit(container, CONTAINER_NAME)
+        assert harness.charm.unit.status == ActiveStatus("Ready")
+
+    def test_on_pebble_check_failed_exporter(self):
+        """
+        arrange: nginx-exporter-up pebble check fails (both checks are on the content-cache container)
+        act: emit pebble_check_failed event for the exporter check
+        assert: unit status is unchanged (exporter failure is non-critical)
+        """
+        harness = self.harness
+        original_status = harness.charm.unit.status
+        container = harness.charm.unit.get_container(CONTAINER_NAME)
+        harness.charm.on[CONTAINER_NAME].pebble_check_failed.emit(container, "nginx-exporter-up")
+        assert harness.charm.unit.status == original_status
+
+    def test_on_pebble_check_recovered_exporter(self):
+        """
+        arrange: nginx-exporter-up pebble check recovers (both checks are on the content-cache container)
+        act: emit pebble_check_recovered event for the exporter check
+        assert: unit status is unchanged
+        """
+        harness = self.harness
+        original_status = harness.charm.unit.status
+        container = harness.charm.unit.get_container(CONTAINER_NAME)
+        harness.charm.on[CONTAINER_NAME].pebble_check_recovered.emit(
+            container, "nginx-exporter-up"
+        )
