         assert action == expected
 
+    @mock.patch("ops.model.Container.pull")
+    def test_report_visits_by_ip_action(self, mock_pull):
+        """
+        arrange: some nginx log lines are simulated
+        act: run the report-visits-by-ip action
+        assert: action result contains the expected IP address
+        """
+        mock_pull.return_value = io.StringIO(f"10.10.10.11 - - [{DATE_NOW}")
+        output = self.harness.run_action("report-visits-by-ip")
+        assert "10.10.10.11" in output.results["ips"]
+
     @pytest.mark.parametrize(
         "test_input,expected", [(f"10.10.10.11 - - [{DATE_NOW}", "10.10.10.11")]
     )
