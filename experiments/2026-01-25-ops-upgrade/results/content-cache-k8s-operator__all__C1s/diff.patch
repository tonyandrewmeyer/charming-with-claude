@@ -0,0 +1,23 @@
+# Copyright 2025 Canonical Ltd.
+# See LICENSE file for licensing details.
+
+"""Configuration class for the Content-cache charm."""
+
+import dataclasses
+
+
+@dataclasses.dataclass(frozen=True)
+class ContentCacheConfig:
+    """Typed representation of charm configuration."""
+
+    site: str = ""
+    backend: str = ""
+    backend_site_name: str = ""
+    cache_all: bool = False
+    cache_inactive_time: str = "10m"
+    cache_max_size: str = "10G"
+    cache_use_stale: str = "error timeout updating http_500 http_502 http_503 http_504"
+    cache_valid: str = "200 1h"
+    client_max_body_size: str = "1m"
+    tls_secret_name: str = ""
+    proxy_cache_revalidate: bool = False
