+def test_pebble_check_failed_wordpress_ready(
+    harness: ops.testing.Harness,
+    setup_replica_consensus: typing.Callable[[], dict],
+):
+    """
+    arrange: after WordPress charm is set up and active.
+    act: fire a pebble-check-failed event for the wordpress-ready check.
+    assert: unit status should transition to MaintenanceStatus.
+    """
+    harness.set_can_connect(harness.model.unit.containers["wordpress"], True)
+    setup_replica_consensus()
+    container = harness.model.unit.get_container("wordpress")
+    harness.charm.on.wordpress_pebble_check_failed.emit(container, "wordpress-ready")
+    assert isinstance(harness.model.unit.status, ops.MaintenanceStatus), (
+        "unit should be in MaintenanceStatus when the wordpress-ready check fails"
+    )
+    assert "health check" in harness.model.unit.status.message.lower(), (
+        "status message should mention the health check failure"
+    )
+
+
+def test_pebble_check_recovered_wordpress_ready(
+    harness: ops.testing.Harness,
+    setup_replica_consensus: typing.Callable[[], dict],
+):
+    """
+    arrange: after the wordpress-ready check has failed and the unit is in MaintenanceStatus.
+    act: fire a pebble-check-recovered event for the wordpress-ready check.
+    assert: unit status should transition back to ActiveStatus.
+    """
+    harness.set_can_connect(harness.model.unit.containers["wordpress"], True)
+    setup_replica_consensus()
+    container = harness.model.unit.get_container("wordpress")
+    harness.charm.on.wordpress_pebble_check_failed.emit(container, "wordpress-ready")
+    assert isinstance(harness.model.unit.status, ops.MaintenanceStatus)
+    harness.charm.on.wordpress_pebble_check_recovered.emit(container, "wordpress-ready")
+    assert isinstance(harness.model.unit.status, ops.ActiveStatus), (
+        "unit should return to ActiveStatus after wordpress-ready check recovers"
+    )
+
+
+def test_pebble_check_failed_apache_exporter(
+    harness: ops.testing.Harness,
+    setup_replica_consensus: typing.Callable[[], dict],
+):
+    """
+    arrange: after WordPress charm is set up and active.
+    act: fire a pebble-check-failed event for the apache-exporter-up check.
+    assert: unit status should remain ActiveStatus (exporter failure is non-critical).
+    """
+    harness.set_can_connect(harness.model.unit.containers["wordpress"], True)
+    setup_replica_consensus()
+    container = harness.model.unit.get_container("wordpress")
+    status_before = harness.model.unit.status
+    harness.charm.on.wordpress_pebble_check_failed.emit(container, "apache-exporter-up")
+    assert harness.model.unit.status == status_before, (
+        "unit status should not change when the apache-exporter-up check fails"
+    )
+
+
+def test_pebble_check_recovered_apache_exporter(
+    harness: ops.testing.Harness,
+    setup_replica_consensus: typing.Callable[[], dict],
+):
+    """
+    arrange: after WordPress charm is set up and active.
+    act: fire a pebble-check-recovered event for the apache-exporter-up check.
+    assert: unit status should remain ActiveStatus (exporter recovery is informational only).
+    """
+    harness.set_can_connect(harness.model.unit.containers["wordpress"], True)
+    setup_replica_consensus()
+    container = harness.model.unit.get_container("wordpress")
+    status_before = harness.model.unit.status
+    harness.charm.on.wordpress_pebble_check_recovered.emit(container, "apache-exporter-up")
+    assert harness.model.unit.status == status_before, (
+        "unit status should not change when the apache-exporter-up check recovers"
+    )
