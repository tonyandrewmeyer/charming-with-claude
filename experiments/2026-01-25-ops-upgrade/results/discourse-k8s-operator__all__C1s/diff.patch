diff --git a/src/config.py b/src/config.py
new file mode 100644
index 0000000..7303e4f
--- /dev/null
+++ b/src/config.py
@@ -0,0 +1,40 @@
+# Copyright 2026 Canonical Ltd.
+# See LICENSE file for licensing details.
+
+"""Configuration for the Discourse charm."""
+
+from pydantic import BaseModel
+
+
+class DiscourseConfig(BaseModel):
+    """Discourse charm configuration."""
+
+    augment_cors_origin: bool = True
+    cors_origin: str = ""
+    developer_emails: str = ""
+    enable_cors: bool = True
+    external_hostname: str = ""
+    force_https: bool = False
+    force_saml_login: bool = False
+    max_category_nesting: int = 2
+    saml_sync_groups: str = ""
+    smtp_address: str = ""
+    smtp_authentication: str = "none"
+    smtp_domain: str = ""
+    smtp_enable_start_tls: str = "true"
+    smtp_force_tls: str = "false"
+    smtp_openssl_verify_mode: str = "none"
+    smtp_password: str = ""
+    smtp_port: int = 587
+    smtp_username: str = ""
+    s3_access_key_id: str = ""
+    s3_backup_bucket: str = ""
+    s3_bucket: str = ""
+    s3_cdn_url: str = ""
+    s3_enabled: bool = False
+    s3_endpoint: str = "https://s3.amazonaws.com"
+    s3_region: str = ""
+    s3_secret_access_key: str = ""
+    s3_install_cors_rule: bool = True
+    throttle_level: str = "none"
+    sidekiq_max_memory: int = 1000
