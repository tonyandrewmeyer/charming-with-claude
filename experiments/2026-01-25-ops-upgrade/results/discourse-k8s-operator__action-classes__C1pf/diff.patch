+
+"""Parameter classes for charm actions."""
+
+import dataclasses
+
+
+@dataclasses.dataclass(frozen=True, kw_only=True)
+class PromoteUserParams:
+    """Parameters for the promote-user action."""
+
+    email: str
+
+
+@dataclasses.dataclass(frozen=True, kw_only=True)
+class CreateUserParams:
+    """Parameters for the create-user action."""
+
+    email: str
+    admin: bool = False
+    active: bool = True
+
+
+@dataclasses.dataclass(frozen=True, kw_only=True)
+class AnonymizeUserParams:
+    """Parameters for the anonymize-user action."""
+
+    username: str
