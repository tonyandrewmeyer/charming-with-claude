+def test_pebble_check_failed(harness: ops.testing.Harness):
+    """
+    arrange: a started WordPress charm.
+    act: emit a pebble-check-failed event for the wordpress-ready check.
+    assert: the unit status should be BlockedStatus indicating the failing check.
+    """
+    harness.begin()
+    container = harness.charm.unit.get_container("wordpress")
+    harness.charm.on["wordpress"].pebble_check_failed.emit(container, "wordpress-ready")
+    assert harness.model.unit.status == ops.BlockedStatus(
+        "Workload health check 'wordpress-ready' failing"
+    )
+
+
+def test_pebble_check_recovered(harness: ops.testing.Harness):
+    """
+    arrange: a started WordPress charm with unit in BlockedStatus from a check failure.
+    act: emit a pebble-check-recovered event for the wordpress-ready check.
+    assert: the unit status should no longer be the check-failure BlockedStatus; reconciliation
+        runs and sets WaitingStatus because pebble is not yet connected.
+    """
+    harness.begin()
+    harness.model.unit.status = ops.BlockedStatus(
+        "Workload health check 'wordpress-ready' failing"
+    )
+    container = harness.charm.unit.get_container("wordpress")
+    harness.charm.on["wordpress"].pebble_check_recovered.emit(container, "wordpress-ready")
+    assert harness.model.unit.status == ops.WaitingStatus("Waiting for pebble")
