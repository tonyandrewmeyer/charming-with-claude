@@ -0,0 +1,30 @@
+# Copyright 2026 Canonical Ltd.
+# See LICENSE file for licensing details.
+
+"""Pydantic models for action parameters."""
+
+import pydantic
+
+
+class PromoteUserAction(pydantic.BaseModel):
+    """Parameters for the promote-user action."""
+
+    email: str = pydantic.Field(description="User email.")
+
+
+class CreateUserAction(pydantic.BaseModel):
+    """Parameters for the create-user action."""
+
+    email: str = pydantic.Field(description="User email.")
+    admin: bool = pydantic.Field(False, description="Whether the user should be an admin.")
+    active: bool = pydantic.Field(
+        True, description="Whether the user should be email-verified and active."
+    )
+
+
+class AnonymizeUserAction(pydantic.BaseModel):
+    """Parameters for the anonymize-user action."""
+
+    username: str = pydantic.Field(
+        description="The unique identifier of the user to anonymize."
+    )
