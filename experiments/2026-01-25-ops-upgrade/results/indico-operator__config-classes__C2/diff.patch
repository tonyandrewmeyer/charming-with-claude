+class CharmConfig(BaseModel):  # pylint: disable=too-few-public-methods
+    """Charm configuration.
+
+    Attributes:
+        customization_debug: Enable debug for custom templates.
+        customization_sources_url: URL for the git repository containing the customization files.
+        enable_roombooking: Enable the room booking plugin.
+        external_plugins: Comma separated list of external plugins to be installed.
+        indico_no_reply_email: Email address used when sending no-reply emails.
+        indico_public_support_email: Email address shown to users on the Contact page.
+        indico_support_email: Email address of the technical manager of the Indico instance.
+        site_url: URL through which Indico is accessed by users.
+    """
+
+    customization_debug: bool = False
+    customization_sources_url: str = ""
+    enable_roombooking: bool = False
+    external_plugins: str = ""
+    indico_no_reply_email: str = "noreply@mydomain.local"
+    indico_public_support_email: str = "support@mydomain.local"
+    indico_support_email: str = "support-tech@mydomain.local"
+    site_url: str = ""
+
+    @validator("site_url")
+    @classmethod
+    def validate_site_url(cls, value: str) -> str:
+        """Validate site_url is a valid URL if provided.
+
+        Args:
+            value: The site_url value to validate.
+
+        Returns:
+            The validated site_url value.
+
+        Raises:
+            ValueError: if site_url is set but does not contain a valid hostname.
+        """
+        if value and not urlparse(value).hostname:
+            raise ValueError("Configuration option site_url is not valid")
+        return value
+
+
